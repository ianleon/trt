# Copy to /etc/default/trtllm-openai-8355 and edit as needed.

# Nemotron runtime settings
HOST=0.0.0.0
PORT=8355
DOCKER_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:1.3.0rc4

# Optional auth token
# HF_TOKEN=hf_xxx

# Runtime tuning
MAX_BATCH_SIZE=8
MAX_INPUT_LEN=32768
MAX_SEQ_LEN=32768
KV_CACHE_FREE_GPU_MEMORY_FRACTION=0.18
